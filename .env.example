# ─────────────────────────────────────────────────────────
#  ChatPulse — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL of this server — CHANGE in production to your deployed URL
# Example: https://distributed-chat-api.railway.app
APP_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────
# Create these by running the SQL commands in the README.
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpassword
POSTGRES_DB=chatdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── MongoDB ──────────────────────────────────────────────
# Native local install (no auth) — use MONGO_URI directly.
# If you're using Docker or a remote MongoDB with auth, replace
# with: mongodb://user:password@host:27017/chatdb?authSource=admin
MONGO_URI=mongodb://localhost:27017/chatdb

# ── JWT ──────────────────────────────────────────────────
# Change this to any long random string (min 32 characters).
# Example: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create credentials → OAuth client ID → Web application
# 3. Add authorized redirect URI: http://localhost:3000/auth/google/callback
# 4. Paste your Client ID and Secret below.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── GitHub OAuth ─────────────────────────────────────────
# 1. Go to: https://github.com/settings/developers → New OAuth App
# 2. Authorization callback URL: http://localhost:3000/auth/github/callback
# 3. Paste your Client ID and Secret below.
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Client URL ───────────────────────────────────────────
# URL of the demo UI. Change if you update PORT above.
CLIENT_URL=http://localhost:3000/demo
